<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Executive Dashboard' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #fafafa; /* พื้นหลังขาวนวล */
            color: #2d3436;
        }

        .dashboard-header {
            padding: 40px 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            background: white;
            margin-bottom: 40px;
        }

        .welcome-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            color: #1a1a1a;
        }

        /* Stat Cards ดีไซน์ใหม่แบบไร้ขอบ */
        .stat-card-premium {
            background: white;
            border: none;
            border-radius: 24px;
            padding: 30px;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        }

        .stat-card-premium:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .icon-circle {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 20px;
            background: #f8f9fa;
            color: #d4af37; /* สีทอง */
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        .stat-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #999;
            font-weight: 600;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            margin-top: 5px;
            color: #1a1a1a;
        }

        /* Table Section */
        .table-glass {
            background: white;
            border-radius: 30px;
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.04);
            overflow: hidden;
        }

        .table-glass thead th {
            background: #fdfdfd;
            border: none;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1px;
            padding: 20px;
            color: #aaa;
        }

        .table-glass td {
            padding: 20px;
            vertical-align: middle;
            border-top: 1px solid #f5f5f5;
        }

        .badge-low-stock {
            background: #fff5f5;
            color: #ff4d4d;
            border-radius: 10px;
            padding: 8px 15px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Action Bar */
        .quick-actions {
            background: #1a1a1a;
            border-radius: 50px;
            padding: 10px 30px;
            display: inline-flex;
            gap: 20px;
        }

        .action-link {
            color: rgba(255,255,255,0.7);
            font-size: 0.85rem;
            text-decoration: none;
            transition: 0.3s;
        }

        .action-link:hover {
            color: #d4af37;
            text-decoration: none;
        }

        .btn-gold {
            background: #d4af37;
            color: white;
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            border: none;
            transition: 0.3s;
        }

        .btn-gold:hover {
            background: #b8860b;
            box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3);
            color: white;
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <header class="dashboard-header">
        <div class="container d-flex justify-content-between align-items-end">
            <div>
                <h2 class="welcome-title">Greetings, <%= user.name %></h2>
                <p class="text-muted mb-0">Here is a curated summary of your business performance today.</p>
            </div>
            <a href="/sales/new" class="btn btn-gold">
                <i class="fa-solid fa-plus-large mr-2"></i> Create New Entry
            </a>
        </div>
    </header>

    <div class="container">
        <div class="row">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card-premium">
                    <div class="icon-circle"><i class="fa-solid fa-crown"></i></div>
                    <span class="stat-label">Daily Revenue</span>
                    <div class="stat-value">฿ <%= stats.revenue %></div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card-premium">
                    <div class="icon-circle"><i class="fa-solid fa-bag-shopping"></i></div>
                    <span class="stat-label">Total Transactions</span>
                    <div class="stat-value"><%= stats.orders %> Units</div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card-premium">
                    <div class="icon-circle"><i class="fa-solid fa-boxes-stacked"></i></div>
                    <span class="stat-label">Inventory Size</span>
                    <div class="stat-value"><%= stats.products %> SKUs</div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card-premium">
                    <div class="icon-circle"><i class="fa-solid fa-gem"></i></div>
                    <span class="stat-label">Loyal Clients</span>
                    <div class="stat-value"><%= stats.members %> Members</div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card table-glass border-0">
                    <div class="card-header bg-white border-0 py-4 px-4">
                        <h6 class="mb-0 font-weight-bold" style="letter-spacing: 1px;">
                            <i class="fa-solid fa-bell-concierge mr-2 text-warning"></i> INVENTORY ALERT
                        </h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Item Nomenclature</th>
                                    <th class="text-center">Stock Level</th>
                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (stats.lowStock.length > 0) { %>
                                    <% stats.lowStock.forEach(p => { %>
                                        <tr>
                                            <td>
                                                <span class="font-weight-bold text-dark"><%= p.name %></span>
                                                <% if (p.stock === 0) { %>
                                                    <span class="ml-2" style="font-size: 10px; color: #ff4d4d;">● CRITICAL</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge-low-stock">
                                                    <%= p.stock === 0 ? 'Depleted' : p.stock + ' Remaining' %>
                                                </span>
                                            </td>
                                            <td class="text-right">
                                                <a href="/manage" class="text-dark font-weight-bold" style="font-size: 0.8rem;">
                                                    Replenish <i class="fa-solid fa-chevron-right ml-1" style="font-size: 10px;"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="text-center py-5">
                                            <i class="fa-solid fa-circle-check text-success mb-2 d-block" style="font-size: 2rem;"></i>
                                            <span class="text-muted">All inventory levels are within optimal parameters.</span>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center my-5">
            <div class="quick-actions shadow-lg">
                <a href="/manage" class="action-link">Catalog</a>
                <span class="text-muted">|</span>
                <a href="/sales/report" class="action-link">Analytics</a>
                <span class="text-muted">|</span>
                <a href="/members" class="action-link">Directory</a>
            </div>
        </div>
    </div>

    <script src="/js/jquery-3.4.1.slim.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
</body>

</html>