<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Transaction Terminal' %></title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --accent-gold: #d4af37;
            --dark-bg: #0f172a; /* Deep Blue-Black */
            --glass: rgba(255, 255, 255, 0.9);
        }

        body { 
            background-color: #f1f5f9; 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            color: #1e293b;
            padding-bottom: 50px;
        }

        /* Container & Card */
        .pos-container {
            margin-top: 30px;
        }

        .crm-card { 
            background: transparent; 
            border: none; 
            overflow: visible; 
        }

        /* Stylish Header */
        .header-charcoal { 
            background: var(--dark-bg); 
            color: white; 
            padding: 40px; 
            border-radius: 30px;
            margin-bottom: -30px; /* Overlap effect */
            position: relative;
            z-index: 1;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.2);
        }

        /* Glass Content Area */
        .content-area {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border-radius: 35px;
            padding: 50px 30px 30px;
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        }

        /* Product Table Customization */
        .table thead th { 
            background: transparent; 
            text-transform: uppercase; 
            font-size: 0.75rem; 
            font-weight: 800;
            letter-spacing: 1px; 
            color: #64748b; 
            border: none;
            padding-bottom: 20px;
        }

        .table tbody tr {
            background: white;
            border-radius: 15px;
            transition: 0.3s;
        }

        .table tbody tr:hover {
            transform: scale(1.01);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .table tbody td { 
            vertical-align: middle; 
            padding: 20px; 
            border: none;
        }

        .table tbody td:first-child { border-radius: 15px 0 0 15px; }
        .table tbody td:last-child { border-radius: 0 15px 15px 0; }

        /* Quantity Input */
        .qty-wrapper {
            background: #f8fafc;
            border-radius: 12px;
            padding: 5px;
            display: inline-flex;
            align-items: center;
            border: 1px solid #e2e8f0;
        }

        .item-qty {
            background: transparent;
            border: none;
            width: 50px;
            text-align: center;
            font-weight: 700;
            color: var(--dark-bg);
        }

        /* Summary Panel (Floating Style) */
        .summary-panel {
            background: white;
            border-radius: 25px;
            padding: 30px;
            border: 1px solid #e2e8f0;
            position: sticky;
            top: 100px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.04);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .total-badge {
            background: #f8fafc;
            padding: 20px;
            border-radius: 18px;
            border: 1px dashed var(--accent-gold);
        }

        /* Button Premium */
        .btn-premium {
            background: linear-gradient(135deg, #d4af37 0%, #f1c40f 100%); 
            color: #000; 
            font-weight: 800; 
            border-radius: 18px;
            padding: 20px; 
            transition: 0.4s; 
            border: none; 
            width: 100%;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
        }

        .btn-premium:hover { 
            transform: translateY(-3px); 
            box-shadow: 0 15px 30px rgba(212, 175, 55, 0.4); 
            filter: brightness(1.1);
        }

        /* --- ส่วนที่ปรับปรุงใหม่ให้ช่องใหญ่ขึ้น --- */
        .form-control-custom {
            border-radius: 15px;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            padding: 15px 20px; /* เพิ่มพื้นที่ภายในให้ช่องสูงขึ้น */
            font-size: 1.1rem;   /* ขยายตัวอักษรให้ใหญ่ขึ้น */
            font-weight: 600;
            height: auto;        /* ปล่อยให้ความสูงขยายตาม padding */
            transition: all 0.3s ease;
        }

        .form-control-custom:focus {
            background: #fff;
            border-color: var(--accent-gold);
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
            transform: translateY(-1px);
        }

        .label-premium {
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #64748b;
            margin-bottom: 10px;
            display: block;
        }
    </style>
</head>

<body>
<%- include('../navbar.ejs') %>

<div class="container pos-container">
    <div class="crm-card">
        <div class="header-charcoal d-flex justify-content-between align-items-center">
            <div>
                <span class="badge badge-warning mb-2" style="background: var(--accent-gold); color: #000; font-weight: 800;">LIVE TERMINAL</span>
                <h2 class="mb-0 font-weight-bold">Transaction <span style="color:var(--accent-gold);">Terminal</span></h2>
            </div>
            <div class="text-right">
                <div class="d-flex align-items-center">
                    <div class="mr-3 text-right d-none d-md-block">
                        <small class="opacity-50 d-block">Operator Status</small>
                        <span class="small font-weight-bold"><i class="fas fa-circle text-success mr-1"></i> System Active</span>
                    </div>
                    <i class="fas fa-calculator fa-3x" style="color: var(--accent-gold); opacity: 0.8;"></i>
                </div>
            </div>
        </div>

        <div class="content-area">
            <form action="/sales/insert" method="POST">
                <div class="row">
                    <div class="col-lg-8">
                        <div class="mb-5">
                            <label class="label-premium">
                                <i class="fas fa-user-circle mr-2 text-warning"></i> Customer Profile
                            </label>
                            <select name="member" class="form-control form-control-custom shadow-sm">
                                <option value="">-- Walk-in Customer (General) --</option>
                                <% if (typeof members !== 'undefined') { %>
                                    <% members.forEach(m => { %>
                                        <option value="<%= m._id %>"><%= m.name %> (<%= m.phone %>)</option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>

                        <div class="table-responsive">
                            <table class="table" style="border-spacing: 0 10px; border-collapse: separate;">
                                <thead>
                                    <tr>
                                        <th>Product / Description</th>
                                        <th class="text-center">Unit Price</th>
                                        <th class="text-center">Qty</th>
                                        <th class="text-right">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof selectedProducts !== 'undefined' && selectedProducts.length > 0) { %>
                                        <% selectedProducts.forEach((p, index) => { %>
                                            <tr>
                                                <td>
                                                    <div class="font-weight-bold" style="font-size: 1.1rem;"><%= p.name %></div>
                                                    <small class="text-muted">SKU: <%= p._id.toString().slice(-8).toUpperCase() %></small>
                                                    <input type="hidden" name="items[<%= index %>][product]" value="<%= p._id %>">
                                                </td>
                                                <td class="text-center font-weight-bold text-muted">
                                                    ฿<%= (p.price || 0).toLocaleString() %>
                                                    <input type="hidden" name="items[<%= index %>][price]" value="<%= p.price %>">
                                                </td>
                                                <td class="text-center">
                                                    <div class="qty-wrapper">
                                                        <input type="number" name="items[<%= index %>][quantity]" value="1" min="1" 
                                                               class="item-qty" data-price="<%= p.price %>">
                                                    </div>
                                                </td>
                                                <td class="text-right">
                                                    <span class="font-weight-bold text-dark" style="font-size: 1.1rem;">฿<span class="item-total"><%= p.price %></span></span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center py-5">
                                                <div class="py-4">
                                                    <i class="fas fa-box-open mb-3 fa-4x opacity-10"></i> 
                                                    <p class="text-muted">No items selected for transaction.</p>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="summary-panel mt-4 mt-lg-0 shadow-lg">
                            <h4 class="font-weight-bold mb-4" style="color: var(--dark-bg);">Payment Details</h4>
                            
                            <div class="mb-4">
                                <label class="label-premium">Payment Method</label>
                                <select name="paymentMethod" class="form-control form-control-custom shadow-sm">
                                    <option value="Cash">💵 &nbsp; Cash Payment</option>
                                    <option value="Transfer">🏦 &nbsp; Bank Transfer</option>
                                    <option value="QR">📱 &nbsp; PromptPay QR</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="label-premium">Discount Rate</label>
                                <div class="input-group">
                                    <input type="number" name="discount" id="discountInput" value="0" min="0" max="100" class="form-control form-control-custom" style="border-radius: 15px 0 0 15px;">
                                    <div class="input-group-append">
                                        <span class="input-group-text bg-white border-left-0" style="border-radius: 0 15px 15px 0; border-color: #e2e8f0; font-weight: bold; padding: 0 20px;">%</span>
                                    </div>
                                </div>
                            </div>

                            <div class="total-badge mt-4">
                                <div class="summary-row mb-1">
                                    <span class="text-muted small">Subtotal</span>
                                    <span class="font-weight-bold small">฿<span id="subtotalDisplay">0</span></span>
                                </div>
                                <div class="summary-row mb-3 text-danger">
                                    <span class="small">Discount Applied</span>
                                    <span class="small">- ฿<span id="discountDisplay">0</span></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-end mt-2">
                                    <span class="h6 mb-1 font-weight-bold">Grand Total</span>
                                    <span class="h2 mb-0 font-weight-extrabold text-success" style="font-weight: 800;">฿<span id="totalDisplay">0</span></span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-premium mt-4">
                                <i class="fas fa-print mr-2"></i> COMPLETE & PRINT
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function calculateTotal(){
    let subtotal = 0;
    document.querySelectorAll('.item-qty').forEach(input => {
        const price = parseFloat(input.dataset.price) || 0;
        const qty = parseInt(input.value) || 0;
        const rowTotal = price * qty;
        const rowTotalElement = input.closest('tr').querySelector('.item-total');
        if(rowTotalElement) rowTotalElement.innerText = rowTotal.toLocaleString();
        subtotal += rowTotal;
    });

    const discountPercent = parseFloat(document.getElementById('discountInput').value) || 0;
    const discountAmount = (subtotal * discountPercent) / 100;
    let finalTotal = subtotal - discountAmount;
    if(finalTotal < 0) finalTotal = 0;

    document.getElementById('subtotalDisplay').innerText = subtotal.toLocaleString();
    document.getElementById('discountDisplay').innerText = discountAmount.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
    document.getElementById('totalDisplay').innerText = Math.round(finalTotal).toLocaleString();
}

document.querySelectorAll('.item-qty').forEach(input => {
    input.addEventListener('input', calculateTotal);
    input.addEventListener('change', calculateTotal);
});
document.getElementById('discountInput').addEventListener('input', calculateTotal);
window.onload = calculateTotal;
</script>

</body>
</html>