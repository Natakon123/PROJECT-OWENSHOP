<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Add New Masterpiece' %></title>
        
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

        <style>
            body {
                background-color: #fafafa;
                font-family: 'Inter', sans-serif;
                color: #333;
            }

            .creation-card {
                background: white;
                border: none;
                border-radius: 30px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.05);
                overflow: hidden;
                margin-top: 50px;
                margin-bottom: 50px;
            }

            .card-aside {
                background: #1a1a1a;
                color: white;
                padding: 40px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                text-align: center;
            }

            .card-aside i {
                color: #d4af37;
                font-size: 3rem;
                margin-bottom: 20px;
            }

            .form-main {
                padding: 50px;
            }

            .form-label-premium {
                font-size: 0.7rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: #999;
                margin-bottom: 8px;
                display: block;
            }

            .input-premium {
                border: 1px solid #eee;
                border-radius: 12px;
                padding: 12px 15px;
                background: #fdfdfd;
                font-size: 0.95rem;
                transition: all 0.3s;
                width: 100%;
            }

            .input-premium:focus {
                border-color: #d4af37;
                background: white;
                box-shadow: 0 5px 15px rgba(212, 175, 55, 0.1);
                outline: none;
            }

            /* Custom File Upload */
            .file-upload-wrapper {
                position: relative;
                width: 100%;
                height: 50px;
                border: 1px dashed #ccc;
                border-radius: 12px;
                display: flex;
                align-items: center;
                padding: 0 15px;
                background: #f9f9f9;
                cursor: pointer;
                transition: 0.3s;
            }

            .file-upload-wrapper:hover {
                border-color: #d4af37;
                background: #fffdf5;
            }

            .file-upload-wrapper input {
                position: absolute;
                top: 0; left: 0; width: 100%; height: 100%;
                opacity: 0;
                cursor: pointer;
            }

            .file-name-display {
                font-size: 0.85rem;
                color: #777;
            }

            /* Buttons */
            .btn-save-master {
                background: #1a1a1a;
                color: white;
                border: none;
                border-radius: 50px;
                padding: 14px 40px;
                font-weight: 600;
                letter-spacing: 1px;
                transition: 0.3s;
            }

            .btn-save-master:hover {
                background: #d4af37;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(212, 175, 55, 0.2);
            }

            .btn-cancel-soft {
                color: #aaa;
                text-decoration: none;
                font-weight: 500;
                font-size: 0.9rem;
                transition: 0.3s;
            }

            .btn-cancel-soft:hover {
                color: #333;
                text-decoration: none;
            }
        </style>
    </head>
    <body>
        <%- include('navbar.ejs') %>

        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="creation-card shadow-lg">
                        <div class="row no-gutters">
                            <div class="col-md-4 card-aside">
                                <i class="fa-solid fa-plus-circle"></i>
                                <h4 class="font-weight-bold">New Addition</h4>
                                <p class="small text-muted" style="color: #666 !important;">
                                    Expanding the collection with excellence. Fill in the details to list your new item.
                                </p>
                            </div>

                            <div class="col-md-8 form-main">
                                <form method="POST" action="/insert" enctype="multipart/form-data">
                                    
                                    <div class="form-group mb-4">
                                        <label class="form-label-premium">Product Nomenclature</label>
                                        <input type="text" class="input-premium" name="name" placeholder="Enter product name" required>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group mb-4">
                                                <label class="form-label-premium">Market Value (THB)</label>
                                                <input type="number" class="input-premium" name="price" placeholder="0.00" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group mb-4">
                                                <label class="form-label-premium" style="color: #b45309;">Initial Inventory</label>
                                                <input type="number" class="input-premium" name="stock" placeholder="Qty" min="0" required>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group mb-4">
                                        <label class="form-label-premium">Visual Representation</label>
                                        <div class="file-upload-wrapper">
                                            <i class="fa-solid fa-cloud-arrow-up mr-2 text-muted"></i>
                                            <span class="file-name-display">Select product imagery...</span>
                                            <input type="file" name="image" id="productImg">
                                        </div>
                                    </div>

                                    <div class="form-group mb-5">
                                        <label class="form-label-premium">Product Narrative</label>
                                        <textarea class="input-premium" rows="3" name="description" placeholder="A brief story about this product..."></textarea>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center">
                                        <a href="/manage" class="btn-cancel-soft">Discard Changes</a>
                                        <button type="submit" class="btn btn-save-master">
                                            Commit to Catalog
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
        <script>
            // แสดงชื่อไฟล์เมื่อมีการเลือกภาพ
            $('#productImg').on('change', function() {
                var fileName = $(this).val().split('\\').pop();
                $(this).siblings('.file-name-display').addClass('text-dark').html(fileName || 'Select product imagery...');
            });
        </script>
    </body>
</html>