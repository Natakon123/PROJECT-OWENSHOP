<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Member Directory' %></title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        body { 
            background-color: #f8fafc; 
            font-family: 'Inter', sans-serif; 
            color: #1e293b;
        }

        .crm-card {
            background: white;
            border-radius: 24px;
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05);
            overflow: hidden;
        }

        /* Stats Card Section */
        .stat-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            border-left: 5px solid #d4af37;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        }

        /* Search Header */
        .header-charcoal {
            background: #1a1d20;
            color: white;
            padding: 35px;
        }

        .search-container {
            position: relative;
            max-width: 500px;
        }

        .search-container i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

        #searchInput {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            padding: 12px 12px 12px 50px;
            color: white;
            transition: 0.3s;
        }

        #searchInput:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: #d4af37;
            box-shadow: none;
            outline: none;
        }

        #searchInput::placeholder { color: #64748b; }

        /* Table Design */
        .table thead th {
            background: #fdfdfd;
            border-top: none;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1.5px;
            color: #94a3b8;
            padding: 20px 25px;
        }

        .table tbody td {
            vertical-align: middle;
            padding: 18px 25px;
            border-bottom: 1px solid #f1f5f9;
        }

        /* Avatar Circle */
        .user-avatar {
            width: 42px;
            height: 42px;
            background: #f1f5f9;
            color: #475569;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
            margin-right: 15px;
        }

        /* Action Buttons */
        .btn-action-circle {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: 0.3s;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
        }

        .btn-edit:hover { background: #eef2ff; color: #6366f1; border-color: #6366f1; }
        .btn-delete:hover { background: #fff1f2; color: #f43f5e; border-color: #f43f5e; }

        .btn-premium {
            background: #d4af37;
            color: #000;
            font-weight: 700;
            border-radius: 14px;
            padding: 12px 28px;
            transition: 0.3s;
            border: none;
        }

        .btn-premium:hover {
            background: #f1c40f;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(212, 175, 55, 0.2);
            color: #000;
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container mt-5 mb-5">
        <div class="row align-items-end mb-4">
            <div class="col-md-7">
                <h2 class="font-weight-bold" style="letter-spacing: -1.5px; font-size: 2.2rem;">Directory</h2>
                <p class="text-muted mb-0">Overview of all active members within the OWENSHOP ecosystem.</p>
            </div>
            <div class="col-md-5 text-md-right mt-3">
                <div class="d-inline-block text-left mr-4">
                    <small class="text-muted font-weight-bold text-uppercase" style="font-size: 0.65rem;">Active Users</small>
                    <h4 class="font-weight-bold mb-0" id="memberCount"><%= members.length %></h4>
                </div>
                <a href="/register" class="btn btn-premium shadow-sm">
                    <i class="fa-solid fa-user-plus mr-2"></i> Enroll Member
                </a>
            </div>
        </div>

        <div class="crm-card shadow-lg">
            <div class="header-charcoal">
                <div class="search-container">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search name, email, or credentials...">
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Member Identity</th>
                            <th>Contact Email</th>
                            <th class="text-center">Phone</th>
                            <th class="text-right">Administration</th>
                        </tr>
                    </thead>
                    <tbody id="memberTable">
                        <% if (members.length > 0) { %>
                            <% members.forEach(function(member){ %>
                            <tr class="member-row">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar">
                                            <%= member.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="font-weight-bold text-dark"><%= member.name %></div>
                                            <small class="text-muted">ID: <%= member._id.toString().slice(-6).toUpperCase() %></small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-secondary"><%= member.email %></td>
                                <td class="text-center">
                                    <span class="badge badge-light py-2 px-3" style="border-radius: 10px;">
                                        <%= member.phone || 'No Data' %>
                                    </span>
                                </td>
                                <td class="text-right">
                                    
                                        <a href="/members/delete/<%= member._id %>" 
                                           class="btn-action-circle btn-delete" 
                                           onclick="return confirm('❗ Permanent Deletion: Are you sure you want to remove this member?')"
                                           title="Terminate Access">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="py-4">
                                        <i class="fa-solid fa-user-slash fa-3x text-light mb-3"></i>
                                        <p class="text-muted">Database is currently empty.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            let filter = this.value.toLowerCase().trim();
            let rows = document.querySelectorAll("#memberTable tr.member-row");
            let visibleCount = 0;

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                if (text.includes(filter)) {
                    row.style.display = "";
                    visibleCount++;
                } else {
                    row.style.display = "none";
                }
            });
            document.getElementById("memberCount").innerText = visibleCount;
        });
    </script>
</body>
</html>