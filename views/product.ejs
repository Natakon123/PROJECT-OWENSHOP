<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ITMI Shop | คลังสินค้า</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="/css/bootstrap.min.css" />

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        body { 
            font-family: 'Inter', 'Sarabun', sans-serif;
            background-color: #ffffff; 
            color: #1e293b;
        }

        .product-container {
            padding-top: 80px;
            padding-bottom: 100px;
        }

        .product-visual {
            background: #f8fafc;
            border-radius: 40px;
            padding: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: sticky;
            top: 100px;
        }

        .product-visual img {
            max-height: 500px;
            width: auto;
            object-fit: contain;
        }

        .product-info {
            padding-left: 50px;
        }

        .brand-tag {
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            color: #d4af37;
            font-size: 0.85rem;
            margin-bottom: 15px;
        }

        .product-name {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 25px;
        }

        .current-price {
            font-size: 2.5rem;
            font-weight: 700;
        }

        .currency {
            font-size: 1.2rem;
            color: #94a3b8;
        }

        .description-text {
            color: #475569;
            line-height: 1.8;
        }

        .btn-buy {
            background: #1a1d20;
            color: white;
            border-radius: 15px;
            padding: 18px;
            font-weight: 700;
            width: 100%;
            border: none;
            transition: 0.3s;
        }

        .btn-buy:hover {
            background: #d4af37;
            color: #000;
        }

        .stock-status {
            margin-top: 15px;
        }

        @media (max-width: 991px) {
            .product-info { padding-left: 10px; margin-top: 30px; }
        }
    </style>
</head>
<body>
    <%- include('navbar.ejs') %>

    <div class="container product-container">
        
        <% if (typeof products !== 'undefined') { %>
            <div class="mb-5 text-center">
                <h1 class="font-weight-bold">Intelligence Results</h1>
                <p class="text-muted text-uppercase letter-spacing-1">พบสินค้าทั้งหมด <%= products.length %> รายการ</p>
            </div>

            <div class="row">
                <% if (products.length > 0) { %>
                    <% products.forEach(function(item) { %>
                        <div class="col-md-4 mb-4">
                            <div class="card search-card p-3 shadow-sm">
                                <img src="/images/products/<%= item.image %>" class="card-img-top" style="height: 250px; object-fit: contain;" onerror="this.src='https://placehold.co/400?text=No+Image'">
                                <div class="card-body text-center">
                                    <h5 class="font-weight-bold mb-2"><%= item.name %></h5>
                                    <p class="text-primary font-weight-bold h4">฿<%= (item.price || 0).toLocaleString() %></p>
                                    <a href="/product/<%= item._id %>" class="btn btn-dark btn-block mt-3" style="border-radius: 10px;">View details</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fas fa-box-open fa-4x text-muted mb-4"></i>
                        <h3>ขออภัย ไม่พบสินค้าที่ตรงตามเงื่อนไข</h3>
                        <a href="/find" class="btn btn-outline-dark mt-3">ลองค้นหาใหม่อีกครั้ง</a>
                    </div>
                <% } %>
            </div>

        <% } else if (typeof product !== 'undefined') { %>
            <div class="row">
                <div class="col-lg-6">
                    <div class="product-visual">
                        <img src="/images/products/<%= product.image %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600?text=ITMI+Product'">
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="product-info">
                        <span class="brand-tag">ITMI Original Series</span>
                        <h1 class="product-name"><%= product.name %></h1>
                        <div class="current-price">
                            <%= (product.price || 0).toLocaleString() %> <span class="currency">฿</span>
                        </div>
                        <hr>
                        <p class="description-text"><%= product.description %></p>
                        <div class="row mt-4">
                            <div class="col-md-6 mb-2">
                                <a href="/cart/add/<%= product._id %>" class="btn btn-outline-dark w-100 py-3" style="border-radius: 12px;">
                                    <i class="fas fa-cart-plus"></i> Add to Cart
                                </a>
                            </div>
                            <div class="col-md-6 mb-2">
                                <form action="/sales/pos-from-cart" method="POST">
                                    <input type="hidden" name="productIds[]" value="<%= product._id %>">
                                    <button class="btn-buy"><i class="fas fa-bolt"></i> Buy Now</button>
                                </form>
                            </div>
                        </div>
                        <div class="stock-status text-success small mt-3">✔ มีสินค้า พร้อมส่งทันที</div>
                    </div>
                </div>
            </div>
        <% } %>

    </div>

    <script src="/js/bootstrap.min.js"></script>
</body>
</html>