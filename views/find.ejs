<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Intelligence Search' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background-color: #fafafa;
            font-family: 'Inter', sans-serif;
            color: #333;
        }

        .search-container {
            max-width: 900px;
            margin: 60px auto;
        }

        .search-card {
            background: white;
            border: none;
            border-radius: 30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.04);
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .search-header {
            background: #1a1a1a;
            padding: 40px;
            text-align: center;
            color: white;
        }

        .search-header i {
            color: #d4af37;
            font-size: 2rem;
            margin-bottom: 15px;
        }

        .search-header h2 {
            font-weight: 600;
            letter-spacing: -1px;
            margin-bottom: 5px;
        }

        .form-label-custom {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #999;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
        }

        .form-label-custom i {
            color: #d4af37;
            margin-right: 8px;
        }

        .input-custom {
            border: 1px solid #eee;
            border-radius: 15px;
            padding: 12px 18px;
            background: #fdfdfd;
            font-size: 0.9rem;
            transition: all 0.3s;
        }

        .input-custom:focus {
            background: white;
            border-color: #d4af37;
            box-shadow: 0 8px 20px rgba(212, 175, 55, 0.1);
            outline: none;
        }

        /* Filter Badges/Checkboxes */
        .filter-option {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 15px;
            border: 1px solid transparent;
            transition: 0.3s;
            cursor: pointer;
            display: flex;
            align-items: center;
        }

        .filter-option:hover {
            border-color: #d4af37;
            background: white;
        }

        .custom-control-input:checked ~ .custom-control-label::before {
            background-color: #d4af37;
            border-color: #d4af37;
        }

        .btn-search-premium {
            background: #1a1a1a;
            color: white;
            border: none;
            border-radius: 50px;
            padding: 15px 40px;
            font-weight: 600;
            letter-spacing: 1px;
            transition: 0.3s;
            width: 100%;
            margin-top: 20px;
        }

        .btn-search-premium:hover {
            background: #d4af37;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        }

        .section-divider {
            height: 1px;
            background: #eee;
            margin: 30px 0;
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container search-container">
        <div class="search-card">
            <div class="search-header">
                <i class="fa-solid fa-magnifying-glass-chart"></i>
                <h2>Catalog Intelligence</h2>
                <p class="text-muted small mb-0">Filtered search for optimized inventory management.</p>
            </div>

            <div class="card-body p-4 p-md-5">
                <form action="/find" method="GET">
                    
                    <div class="row">
                        <div class="col-md-7">
                            <div class="form-group mb-4">
                                <label class="form-label-custom"><i class="fa-solid fa-tag"></i> Nomenclature (Exact Match)</label>
                                <input type="text" class="form-control input-custom" name="name" placeholder="Search by exact name...">
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group mb-4">
                                        <label class="form-label-custom"><i class="fa-solid fa-arrow-down-wide-short"></i> Floor Price</label>
                                        <input type="number" class="form-control input-custom" name="minPrice" placeholder="Min ฿">
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group mb-4">
                                        <label class="form-label-custom"><i class="fa-solid fa-arrow-up-wide-short"></i> Ceiling Price</label>
                                        <input type="number" class="form-control input-custom" name="maxPrice" placeholder="Max ฿">
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label-custom"><i class="fa-solid fa-ban"></i> Exclusion Parameter</label>
                                <input type="text" class="form-control input-custom" name="exclude" placeholder="Except this item...">
                            </div>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label-custom"><i class="fa-solid fa-sliders"></i> Quick Filters</label>
                            
                            <div class="custom-control custom-checkbox filter-option">
                                <input type="checkbox" class="custom-control-input" id="highPrice" name="highPriceOnly">
                                <label class="custom-control-label font-weight-bold" for="highPrice" style="cursor: pointer;">
                                    Premium Tier <br>
                                    <small class="text-muted">Price > ฿5,000</small>
                                </label>
                            </div>

                            <div class="custom-control custom-checkbox filter-option">
                                <input type="checkbox" class="custom-control-input" id="lowPrice" name="lowPriceOnly">
                                <label class="custom-control-label font-weight-bold" for="lowPrice" style="cursor: pointer;">
                                    Standard Tier <br>
                                    <small class="text-muted">Price < ฿2,000</small>
                                </label>
                            </div>

                            <p class="text-muted mt-3" style="font-size: 0.7rem;">
                                <i class="fa-solid fa-circle-info mr-1"></i> 
                                Multiple filters can be applied simultaneously for higher precision.
                            </p>
                        </div>
                    </div>

                    <div class="section-divider"></div>

                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <button type="submit" class="btn-search-premium">
                                Execute Search
                            </button>
                        </div>
                    </div>

                </form>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <a href="/manage" class="text-muted small text-decoration-none">
                <i class="fa-solid fa-arrow-left mr-1"></i> Back to Catalog Management
            </a>
        </div>
    </div>

</body>

</html>