<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Search Results' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
    :root {
        --accent: #d4af37;
        --bg-light: #fbfbfd; /* Apple-style bg */
    }

    body {
        font-family: 'Inter', 'Sarabun', sans-serif;
        background-color: var(--bg-light);
        color: #1d1d1f;
        overflow-x: hidden;
    }

    .cart-header {
        padding: 80px 0 40px;
    }

    .cart-title {
        font-weight: 700;
        letter-spacing: -1.5px;
        font-size: 3rem;
        color: #1d1d1f;
    }

    /* Cart Item Styling */
    .cart-item {
        background: #ffffff;
        border-radius: 28px;
        padding: 30px;
        margin-bottom: 24px;
        border: 1px solid rgba(0,0,0,0.03);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
    }

    .cart-item:hover {
        box-shadow: 0 20px 40px rgba(0,0,0,0.06);
        transform: scale(1.01);
    }

    .product-img-wrapper {
        width: 140px;
        height: 140px;
        background: #f5f5f7;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 30px;
        overflow: hidden;
    }

    .product-img-wrapper img {
        max-width: 85%;
        transition: 0.5s;
    }

    .cart-item:hover .product-img-wrapper img {
        transform: scale(1.1) rotate(-5deg);
    }

    .product-info h5 {
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 1.4rem;
        letter-spacing: -0.5px;
    }

    .product-info p {
        color: #86868b;
        font-size: 0.95rem;
    }

    /* Summary Card Styling */
    .summary-card {
        background: #1d1d1f;
        color: #f5f5f7;
        border-radius: 35px;
        padding: 45px;
        position: sticky;
        top: 120px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.2);
    }

    .summary-title {
        font-weight: 600;
        font-size: 1.8rem;
        margin-bottom: 35px;
        letter-spacing: -0.5px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 18px;
        font-size: 1.05rem;
        color: #a1a1a6;
    }

    .total-row {
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid rgba(255,255,255,0.1);
    }

    .grand-total-price {
        font-size: 2.5rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -1px;
    }

    /* Checkout Button with Shimmer */
    .btn-pay {
        background: var(--accent);
        color: #000;
        border: none;
        border-radius: 20px;
        padding: 22px;
        width: 100%;
        font-weight: 700;
        font-size: 1.2rem;
        margin-top: 30px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: 0.3s;
    }

    .btn-pay:hover {
        background: #f1c40f;
        transform: translateY(-2px);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.4);
    }

    /* Remove Link */
    .remove-link {
        color: #ff3b30;
        font-weight: 500;
        text-decoration: none !important;
        transition: 0.2s;
        font-size: 0.85rem;
    }

    .remove-link:hover {
        opacity: 0.7;
    }

    .qty-badge {
        background: #f5f5f7;
        color: #1d1d1f;
        padding: 4px 14px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
    }
</style>

<%- include('navbar.ejs') %>

<div class="container mb-5 mt-4">
    <div class="cart-header">
        <h1 class="cart-title">Review your <span style="color: var(--accent);">Bag.</span></h1>
        <p class="text-muted" style="font-size: 1.1rem;">เช็ครายการสินค้า และพร้อมสัมผัสประสบการณ์เทคโนโลยีใหม่</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <% if(cart && cart.length > 0) { %>
                <% cart.forEach(item => { %>
                    <div class="cart-item">
                        <div class="product-img-wrapper">
                            <img src="./images/products/<%= item.image %>" alt="<%= item.name %>" style="filter: drop-shadow(0 10px 20px rgba(0,0,0,0.1));">
                        </div>

                        <div class="product-info flex-grow-1">
                            <span class="badge badge-pill badge-light mb-2" style="font-size: 10px; text-transform: uppercase; letter-spacing: 1px;">Premium Edition</span>
                            <h5><%= item.name %></h5>
                            <p><i class="fa-solid fa-circle-check text-success mr-1"></i> In Stock & Ready to ship</p>
                            
                            <a href="/cart/remove/<%= item.index %>" class="remove-link d-inline-block mt-3">
                                <i class="fa-regular fa-trash-can mr-1"></i> Remove
                            </a>
                        </div>

                        <div class="text-right">
                            <div class="qty-badge mb-2 d-inline-block">Qty: <%= item.qty %></div>
                            <div style="font-size: 1.5rem; font-weight: 700; color: #1d1d1f;">
                                ฿<%= (item.price * item.qty).toLocaleString() %>
                            </div>
                            <small class="text-muted">฿<%= item.price.toLocaleString() %> / unit</small>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state text-center py-5">
                    <div class="mb-4">
                        <i class="fa-solid fa-bag-shopping" style="font-size: 5rem; color: #e5e5e7;"></i>
                    </div>
                    <h2 class="font-weight-bold">Your bag is empty.</h2>
                    <p class="text-muted">ดูเหมือนว่าคุณยังไม่ได้เลือกสินค้าชิ้นไหนเลย</p>
                    <a href="/" class="btn btn-dark btn-lg mt-4 px-5" style="border-radius: 18px; font-size: 1rem;">Shop our latest models</a>
                </div>
            <% } %>
        </div>

        <div class="col-lg-4">
            <div class="summary-card">
                <h4 class="summary-title">Order Summary</h4>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span style="color: #fff;">฿<%= (totalPrice || 0).toLocaleString() %></span>
                </div>

                <div class="summary-row">
                    <span>Shipping</span>
                    <span class="text-success" style="font-weight: 600;">FREE</span>
                </div>

                <div class="summary-row">
                    <span>VAT (7%)</span>
                    <span style="color: #fff;">฿<%= (totalPrice * 0.07 || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></span>
                </div>

                <div class="total-row">
                    <div class="d-flex justify-content-between align-items-end">
                        <div>
                            <span class="h5" style="color: #a1a1a6;">Total</span>
                            <div class="grand-total-price">฿<%= (totalPrice || 0).toLocaleString() %></div>
                        </div>
                        <div class="text-right pb-2">
                            <small class="text-muted">Tax included</small>
                        </div>
                    </div>
                </div>

                <form action="/sales/pos-from-cart" method="POST" class="mt-2">
                    <% if (cart && cart.length > 0) { %>
                        <% cart.forEach(item => { %>
                            <input type="hidden" name="productIds[]" value="<%= item._id %>">
                            <input type="hidden" name="quantities[]" value="<%= item.qty %>">
                        <% }) %>
                        <button type="submit" class="btn-pay">
                            Checkout All Items <i class="fa-solid fa-arrow-right ml-2" style="font-size: 0.9rem;"></i>
                        </button>
                    <% } else { %>
                        <button type="button" class="btn-pay" disabled style="opacity: 0.3; cursor: not-allowed;">
                            Bag is empty
                        </button>
                    <% } %>
                </form>

                <div class="d-flex justify-content-center mt-4 pt-2 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
                    <div class="px-2 opacity-50"><i class="fa-brands fa-cc-visa fa-2x"></i></div>
                    <div class="px-2 opacity-50"><i class="fa-brands fa-cc-mastercard fa-2x"></i></div>
                    <div class="px-2 opacity-50"><i class="fa-brands fa-apple-pay fa-2x"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>