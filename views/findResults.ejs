<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Search Results' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background-color: #fafafa;
            font-family: 'Inter', sans-serif;
            color: #333;
        }

        .results-header {
            padding: 40px 0;
            margin-bottom: 20px;
        }

        .btn-return {
            color: #999;
            font-size: 0.85rem;
            text-decoration: none;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
        }

        .btn-return:hover {
            color: #1a1a1a;
            text-decoration: none;
        }

        /* Product Card Styling */
        .product-item {
            background: white;
            border: none;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            height: 100%;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .product-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .img-wrapper {
            width: 100%;
            height: 220px;
            overflow: hidden;
            background: #f8f8f8;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s;
        }

        .product-item:hover .product-img {
            transform: scale(1.1);
        }

        .product-info {
            padding: 25px;
        }

        .product-category {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #d4af37;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }

        .product-name {
            font-size: 1.1rem;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 12px;
            line-height: 1.4;
        }

        .product-description {
            font-size: 0.85rem;
            color: #888;
            margin-bottom: 20px;
            height: 40px;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 15px;
            border-top: 1px solid #f5f5f5;
        }

        .product-price {
            font-weight: 700;
            font-size: 1.2rem;
            color: #1a1a1a;
        }

        .price-symbol {
            font-size: 0.8rem;
            color: #aaa;
            margin-right: 2px;
        }

        .empty-state {
            padding: 100px 0;
            text-align: center;
            color: #ccc;
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container">
        <div class="results-header d-flex justify-content-between align-items-end">
            <div>
                <a href="/findindex" class="btn-return mb-2">
                    <i class="fa-solid fa-chevron-left mr-2"></i> Modify Parameters
                </a>
                <h2 class="font-weight-bold" style="letter-spacing: -1px;">Search Results</h2>
                <p class="text-muted small mb-0">Found <%= products.length %> items matching your criteria.</p>
            </div>
            <div class="text-right">
                <span class="badge badge-light px-3 py-2" style="border-radius: 10px; font-weight: 400; color: #666;">
                    Sorted by: Relevance
                </span>
            </div>
        </div>

        <div class="row">
            <% if (products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="col-lg-4 col-md-6 mb-5">
                        <div class="product-item">
                            <div class="img-wrapper">
                                <img src="/images/products/<%= product.image %>" 
                                     class="product-img" 
                                     alt="<%= product.name %>"
                                     onerror="this.src='https://placehold.co/600x400?text=No+Image'">
                            </div>

                            <div class="product-info">
                                <span class="product-category">Inventory Item</span>
                                <h5 class="product-name"><%= product.name %></h5>
                                <p class="product-description">
                                    <%= product.description || 'No detailed description provided for this item.' %>
                                </p>
                                
                                <div class="product-footer">
                                    <div class="product-price">
                                        <span class="price-symbol">฿</span><%= product.price.toLocaleString() %>
                                    </div>
                                    <a href="/manage" class="text-dark">
                                        <i class="fa-solid fa-arrow-right-long"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 empty-state">
                    <i class="fa-solid fa-box-open fa-4x mb-4" style="color: #eee;"></i>
                    <h4 class="text-dark font-weight-bold">No items found</h4>
                    <p>Adjust your search filters and try again.</p>
                    <a href="/findindex" class="btn btn-dark rounded-pill px-4 mt-3" style="background: #1a1a1a;">
                        Refine Search
                    </a>
                </div>
            <% } %>
        </div>

        <div class="text-center py-5">
            <p class="text-muted small" style="letter-spacing: 1px;">END OF CATALOG</p>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>