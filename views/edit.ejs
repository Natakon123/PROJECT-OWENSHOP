<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #fafafa;
        font-family: 'Inter', sans-serif;
        color: #333;
    }

    .edit-card-premium {
        background: white;
        border: none;
        border-radius: 30px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-top: 40px;
    }

    .header-accent {
        background: #1a1a1a;
        padding: 40px 20px;
        color: white;
        text-align: center;
    }

    .header-accent h3 {
        font-weight: 600;
        letter-spacing: -0.5px;
        margin-bottom: 5px;
    }

    .header-accent .sku-badge {
        background: rgba(212, 175, 55, 0.2);
        color: #d4af37;
        border: 1px solid #d4af37;
        font-size: 0.7rem;
        padding: 4px 12px;
        border-radius: 50px;
    }

    .form-label-custom {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #999;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
    }

    .form-label-custom i {
        color: #d4af37;
        margin-right: 8px;
        font-size: 0.8rem;
    }

    .input-field-custom {
        border: 1px solid #eee;
        border-radius: 15px;
        padding: 14px 18px;
        background: #fdfdfd;
        font-size: 0.95rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .input-field-custom:focus {
        background: white;
        border-color: #d4af37;
        box-shadow: 0 8px 20px rgba(212, 175, 55, 0.1);
        outline: none;
    }

    /* สไตล์ราคาพิเศษ */
    .price-input-wrapper {
        position: relative;
    }
    .currency-symbol {
        position: absolute;
        right: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #ccc;
        font-weight: 600;
        font-size: 0.8rem;
    }

    /* จัดการรูปภาพใหม่ */
    .image-edit-box {
        background: #f9f9f9;
        border-radius: 20px;
        padding: 25px;
        border: 1px dashed #ddd;
    }

    .current-preview {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 18px;
        border: 4px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    /* ปุ่ม */
    .btn-save-gold {
        background: #1a1a1a;
        color: white;
        border-radius: 15px;
        padding: 15px;
        font-weight: 600;
        border: none;
        transition: 0.3s;
    }

    .btn-save-gold:hover {
        background: #d4af37;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        color: white;
    }

    .btn-cancel-link {
        color: #999;
        font-weight: 500;
        text-decoration: none;
        font-size: 0.9rem;
        transition: 0.3s;
    }

    .btn-cancel-link:hover {
        color: #333;
        text-decoration: none;
    }
</style>

<%- include('navbar.ejs') %>

<div class="container py-5">
    <div class="edit-card-premium shadow-lg mx-auto" style="max-width: 700px;">
        <div class="header-accent">
            <i class="fa-solid fa-pen-nib mb-3" style="font-size: 1.5rem; color: #d4af37;"></i>
            <h3>Refine Product</h3>
            <span class="sku-badge">REFERENCE ID: #<%= item._id %></span>
        </div>

        <div class="card-body p-4 p-md-5">
            <form action="/update" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="id" value="<%= item._id %>">

                <div class="form-group mb-4">
                    <label class="form-label-custom"><i class="fa-solid fa-signature"></i> Nomenclature</label>
                    <input type="text" name="name" class="form-control input-field-custom" value="<%= item.name %>" placeholder="Enter product name..." required>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-4">
                            <label class="form-label-custom"><i class="fa-solid fa-tag"></i> Cost Investment</label>
                            <div class="price-input-wrapper">
                                <input type="number" name="cost" class="form-control input-field-custom" value="<%= item.cost || 0 %>" required>
                                <span class="currency-symbol">THB</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-4">
                            <label class="form-label-custom"><i class="fa-solid fa-coins"></i> Market Price</label>
                            <div class="price-input-wrapper">
                                <input type="number" name="price" class="form-control input-field-custom" value="<%= item.price %>" style="color: #d4af37; font-weight: 700;" required>
                                <span class="currency-symbol">THB</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label-custom"><i class="fa-solid fa-warehouse"></i> Inventory Quantity</label>
                    <input type="number" name="stock" class="form-control input-field-custom" value="<%= item.stock || 0 %>" required>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label-custom"><i class="fa-solid fa-quote-left"></i> Product Narrative</label>
                    <textarea name="description" class="form-control input-field-custom" rows="3" placeholder="Provide a detailed description..."><%= item.description %></textarea>
                </div>

                <div class="form-group mb-5">
                    <label class="form-label-custom"><i class="fa-solid fa-camera-retro"></i> Visual Identity</label>
                    <div class="image-edit-box d-flex align-items-center">
                        <img src="/images/products/<%= item.image %>" class="current-preview mr-4">
                        <div class="flex-grow-1">
                            <input type="file" name="image" class="mb-2" style="font-size: 0.8rem;">
                            <p class="mb-0" style="font-size: 0.7rem; color: #aaa;">Leave empty to retain the current masterpiece.</p>
                        </div>
                    </div>
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-block btn-save-gold shadow">
                        Update Catalog Entry
                    </button>
                    <div class="mt-3">
                        <a href="/manage" class="btn-cancel-link">
                             Return to Catalog
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>