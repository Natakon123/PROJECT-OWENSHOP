<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authentication Success | OWENSHOP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    
    <style>
        * { box-sizing: border-box; }
        body { 
            background-color: #0f1113; /* Charcoal Black */
            font-family: 'Inter', sans-serif;
            height: 100vh; 
            margin: 0;
            display: flex; 
            align-items: center; 
            justify-content: center; 
            color: #ffffff;
            overflow: hidden;
        }

        /* เอฟเฟกต์แสง Background จางๆ */
        .bg-glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
            z-index: 0;
        }

        .welcome-card { 
            background: rgba(26, 29, 32, 0.8); 
            backdrop-filter: blur(20px); 
            border-radius: 30px; 
            padding: 60px 50px; 
            border: 1px solid rgba(212, 175, 55, 0.15); /* ขอบสีทองบางๆ */
            text-align: center;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
            position: relative;
            z-index: 1;
        }

        .brand-icon {
            font-size: 3rem;
            color: #d4af37;
            margin-bottom: 25px;
            display: inline-block;
        }

        h1 { 
            font-weight: 700; 
            letter-spacing: -1.5px;
            font-size: 2.2rem;
            margin-bottom: 10px;
        }

        .user-name {
            color: #d4af37; /* เน้นชื่อผู้ใช้ด้วยสีทอง */
        }

        .subtitle {
            color: #888;
            font-size: 1rem;
            margin-bottom: 40px;
        }

        /* Custom Modern Loader */
        .loader-container {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .loader-bar {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #d4af37, #f1c40f);
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
            border-radius: 10px;
            animation: loadProgress 2.5s ease-in-out forwards;
        }

        @keyframes loadProgress {
            0% { width: 0%; }
            50% { width: 70%; }
            100% { width: 100%; }
        }

        .status-text {
            margin-top: 15px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #555;
            animation: pulseText 1.5s infinite;
        }

        @keyframes pulseText {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <div class="welcome-card animate__animated animate__zoomIn">
        <div class="brand-icon">
            <i class="fa-solid fa-shield-check"></i> <img src="/images/home/OWEN-Photoroom (1).png" alt="OWEN" style="height: 40px; display: block; margin: 0 auto 20px;">
        </div>

        <h1>Welcome, <span class="user-name"><%= user.name %></span></h1>
        <p class="subtitle">ระบบยืนยันตัวตนสำเร็จ กำลังเข้าสู่แผงควบคุมหลัก</p>
        
        <div class="loader-container">
            <div class="loader-bar"></div>
        </div>
        
        <p class="status-text">Synchronizing Data...</p>
    </div>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <script>
        // เปลี่ยนหน้าเมื่อโหลด Bar เสร็จ (ประมาณ 2.8 วินาที)
        setTimeout(() => {
            window.location.href = "/dashboard";
        }, 2800);
    </script>
</body>
</html>