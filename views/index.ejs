<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Premium Collection' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        :root {
            --primary-accent: #6366f1;
            --secondary-accent: #a855f7;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --dark-surface: #111827;
        }

        body { 
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc; 
            color: #1f2937;
        }

        /* Header Branding */
        .hero-section {
            padding: 80px 0 60px;
            text-align: center;
        }

        .hero-badge {
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary-accent);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            display: inline-block;
            margin-bottom: 20px;
        }

        .hero-title {
            font-weight: 800;
            font-size: 3.5rem;
            letter-spacing: -2px;
            background: linear-gradient(135deg, #1e293b 0%, #4f46e5 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
        }

        /* Smart Search Terminal */
        .search-terminal {
            background: white;
            border-radius: 30px;
            padding: 10px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0,0,0,0.03);
            margin-bottom: 70px;
        }

        .inner-search {
            padding: 20px 30px;
        }

        .form-control-minimal {
            border: none;
            background: transparent;
            font-size: 1.1rem;
            font-weight: 500;
            padding: 10px 0;
            border-bottom: 2px solid #f1f5f9;
            border-radius: 0;
            transition: 0.3s;
        }

        .form-control-minimal:focus {
            box-shadow: none;
            border-color: var(--primary-accent);
            outline: none;
        }

        .btn-launch {
            background: var(--dark-surface);
            color: white;
            border-radius: 20px;
            height: 60px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: 0.4s;
        }

        .btn-launch:hover {
            background: var(--primary-accent);
            transform: scale(1.02);
            color: white;
        }

        /* Product Card: The "Object" Style */
        .product-object {
            background: white;
            border-radius: 32px;
            border: 1px solid #f1f5f9;
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            height: 100%;
            position: relative;
        }

        .product-object:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.1);
            border-color: transparent;
        }

        .img-container {
            padding: 15px;
            position: relative;
        }

        .img-container img {
            border-radius: 24px;
            height: 280px;
            object-fit: cover;
            width: 100%;
        }

        .float-price {
            position: absolute;
            bottom: 30px;
            right: 30px;
            background: white;
            padding: 10px 20px;
            border-radius: 18px;
            font-weight: 800;
            font-size: 1.2rem;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            color: var(--dark-surface);
        }

        .object-body {
            padding: 0 30px 30px;
        }

        .obj-category {
            font-size: 0.7rem;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: block;
        }

        .obj-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--dark-surface);
            margin-bottom: 12px;
            text-decoration: none;
            display: block;
        }

        .obj-desc {
            color: #64748b;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        .btn-view-obj {
            width: 50px;
            height: 50px;
            border-radius: 15px;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--dark-surface);
            transition: 0.3s;
            text-decoration: none;
        }

        .product-object:hover .btn-view-obj {
            background: var(--dark-surface);
            color: white;
        }

    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container">
        <header class="hero-section">
            <span class="hero-badge">Latest Technology</span>
            <h1 class="hero-title">OWENShop Collections</h1>
            <p class="text-muted lead mx-auto" style="max-width: 600px;">สัมผัสประสบการณ์ช้อปปิ้งสินค้าไอทีที่คัดสรรมาเพื่อไลฟ์สไตล์ยุคใหม่ของคุณ</p>
        </header>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="search-terminal">
                    <form action="/find" method="GET" class="inner-search">
                        <div class="row g-4 align-items-center">
                            <div class="col-md-4">
                                <label class="small text-muted font-weight-bold mb-2">FLOOR PRICE</label>
                                <input type="number" class="form-control form-control-minimal" name="minPrice" placeholder="฿ 0">
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted font-weight-bold mb-2">CEILING PRICE</label>
                                <input type="number" class="form-control form-control-minimal" name="maxPrice" placeholder="฿ 50,000+">
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-launch w-100 shadow-sm">
                                    <i class="fa-solid fa-rocket mr-2"></i> SEARCH CATALOG
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="row">
            <% Object.values(products).forEach(function(item){ %>
                <div class="col-xl-4 col-md-6 mb-5">
                    <div class="product-object">
                        <div class="img-container">
                            <a href="/<%= item._id %>">
                                <img src="./images/products/<%= item.image %>" alt="<%= item.name %>">
                            </a>
                            <div class="float-price">
                                <span style="font-size: 0.8rem; font-weight: 400; color: #94a3b8;">฿</span>
                                <%= (item.price || 0).toLocaleString() %>
                            </div>
                        </div>
                        
                        <div class="object-body">
                            <span class="obj-category">Official Hardware</span>
                            <a href="/<%= item._id %>" class="obj-title">
                                <%= item.name %>
                            </a>
                            <p class="obj-desc">
                                <%= item.description %>
                            </p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <span class="small font-weight-bold text-success">
                                    <i class="fa-solid fa-circle-check mr-1"></i> In Stock
                                </span>
                                <a href="/<%= item._id %>" class="btn-view-obj">
                                    <i class="fa-solid fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="js/bootstrap.min.js"></script>
</body>

</html>